<Window x:Class="Clicky.App.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Clicky"
        Width="500" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#1A1A2E"
        FontFamily="Segoe UI">

    <Window.Resources>

        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Background" Value="#4A9EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Background" Value="#2A2A4E"/>
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A5E"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A9EFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="StepNum" TargetType="TextBlock">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Foreground" Value="#4A9EFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <StackPanel Margin="28">

        <!-- ── HEADER ─────────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <!-- Triangle logo shape -->
            <Path Data="M0,14 L8,0 L16,14 Z" Fill="#4A9EFF"
                  Width="16" Height="14" Stretch="Fill"
                  VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Clicky is running" Foreground="White"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Foreground="#6666AA" FontSize="11" Margin="0,0,0,20">
            Windows port of Clicky by Farza — AI voice + screen assistant
        </TextBlock>

        <!-- ── TRAY INSTRUCTIONS ──────────────────────────── -->
        <Border Background="#0D0D1E" BorderBrush="#2A2A4E" BorderThickness="1"
                CornerRadius="6" Padding="16,12" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8">
                    Find the tray icon
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="#AAAACC" FontSize="12" LineHeight="20">
                    Look for the <Run Foreground="#4A9EFF" FontWeight="SemiBold">▲ triangle</Run>
                    in the bottom-right corner of your taskbar (you may need to click the
                    <Run Foreground="White">∧</Run> arrow to expand hidden icons).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="#AAAACC" FontSize="12"
                           LineHeight="20" Margin="0,6,0,0">
                    <Run Foreground="White" FontWeight="SemiBold">Right-click</Run>
                    the icon to open Settings or quit.
                    Hold <Run Foreground="White" FontFamily="Consolas">Ctrl + Win + Space</Run>
                    to speak.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── FIRST-TIME SETUP ───────────────────────────── -->
        <TextBlock Text="FIRST-TIME SETUP" Foreground="#4A9EFF"
                   FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>

        <TextBlock TextWrapping="Wrap" Foreground="#AAAACC" FontSize="12"
                   LineHeight="20" Margin="0,0,0,16">
            Clicky needs three API keys to work. Sign up for each service (all have free tiers),
            then paste your keys via
            <Run Foreground="White" FontWeight="SemiBold">tray → Settings → API Configuration</Run>
            or click the button below.
        </TextBlock>

        <!-- Step 1 -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="#1E2A4E" CornerRadius="11" Width="22" Height="22"
                    VerticalAlignment="Top" Margin="0,1,0,0">
                <TextBlock Text="1" Style="{StaticResource StepNum}"/>
            </Border>
            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Cloudflare Worker" Foreground="White"
                               FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="  —  " Foreground="#3A3A5E" VerticalAlignment="Center"/>
                    <Button Content="deployment guide →" Style="{StaticResource LinkBtn}"
                            Tag="https://developers.cloudflare.com/workers/get-started/guide/"
                            Click="Link_Click" VerticalAlignment="Center"/>
                    <TextBlock Text="  ·  " Foreground="#3A3A5E" VerticalAlignment="Center"/>
                    <Button Content="free tier →" Style="{StaticResource LinkBtn}"
                            Tag="https://workers.cloudflare.com/"
                            Click="Link_Click" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Proxies your voice and screenshot to Claude (Anthropic)"
                           Foreground="#6666AA" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Step 2 -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="#1E2A4E" CornerRadius="11" Width="22" Height="22"
                    VerticalAlignment="Top" Margin="0,1,0,0">
                <TextBlock Text="2" Style="{StaticResource StepNum}"/>
            </Border>
            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AssemblyAI" Foreground="White"
                               FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="  —  " Foreground="#3A3A5E" VerticalAlignment="Center"/>
                    <Button Content="assemblyai.com →" Style="{StaticResource LinkBtn}"
                            Tag="https://www.assemblyai.com/"
                            Click="Link_Click" VerticalAlignment="Center"/>
                    <TextBlock Text="  ·  " Foreground="#3A3A5E" VerticalAlignment="Center"/>
                    <TextBlock Text="100 hours/month free" Foreground="#55AA55"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Real-time speech-to-text transcription"
                           Foreground="#6666AA" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Step 3 -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="#1E2A4E" CornerRadius="11" Width="22" Height="22"
                    VerticalAlignment="Top" Margin="0,1,0,0">
                <TextBlock Text="3" Style="{StaticResource StepNum}"/>
            </Border>
            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Cartesia" Foreground="White"
                               FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="  —  " Foreground="#3A3A5E" VerticalAlignment="Center"/>
                    <Button Content="cartesia.ai →" Style="{StaticResource LinkBtn}"
                            Tag="https://cartesia.ai/"
                            Click="Link_Click" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Streams Claude's reply through your speakers with near-zero latency"
                           Foreground="#6666AA" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ── ACTIONS ────────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Got it, dismiss" Style="{StaticResource SecondaryBtn}"
                    Click="Dismiss_Click" Margin="0,0,10,0"/>
            <Button Content="Open API Configuration →" Style="{StaticResource PrimaryBtn}"
                    Click="OpenConfig_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
