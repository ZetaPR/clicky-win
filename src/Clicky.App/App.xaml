<Application x:Class="Clicky.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar">
    <Application.Resources>
        <tb:TaskbarIcon x:Key="TrayIcon"
                        ToolTipText="Clicky"
                        IconSource="/Assets/clicky-icon.ico"
                        Id="3F7A8B2C-D4E9-4F01-BC56-7890ABCDEF12">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Clicky" IsEnabled="False" FontWeight="Bold" />
                    <Separator />
                    <MenuItem Header="Settings" Click="SettingsMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="Quit" Click="QuitMenuItem_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
