<Window x:Class="Clicky.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clicky — Settings"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#1A1A2E"
        FontFamily="Segoe UI">

    <Window.Resources>

        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Background" Value="#4A9EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource FlatButtonTemplate}"/>
            <Setter Property="Background" Value="#2A2A4E"/>
            <Setter Property="Foreground" Value="#AAAACC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A5E"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D0D1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#4A9EFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <StackPanel Margin="24">

        <TextBlock Text="Settings" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- ── APPEARANCE ─────────────────────────────────── -->
        <TextBlock Text="APPEARANCE" Foreground="#4A9EFF" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Text="Cursor mode" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <RadioButton x:Name="PersistentMode" Content="Persistent" GroupName="CursorMode" Margin="0,0,24,0"/>
            <RadioButton x:Name="HiddenMode"     Content="Hidden"     GroupName="CursorMode"/>
        </StackPanel>
        <TextBlock Text="Persistent: triangle always follows cursor.  Hidden: appears only on hotkey press."
                   Foreground="#555577" FontSize="10" FontStyle="Italic" Margin="0,0,0,16"/>

        <TextBlock Text="Colors" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Arrow"  Foreground="#666688" FontSize="10"/>
            <TextBlock Grid.Column="2" Text="Loader" Foreground="#666688" FontSize="10"/>
            <TextBlock Grid.Column="4" Text="Bars"   Foreground="#666688" FontSize="10"/>
        </Grid>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ArrowColorBox"/>
            <TextBox Grid.Column="2" x:Name="LoaderColorBox"/>
            <TextBox Grid.Column="4" x:Name="BarsColorBox"/>
        </Grid>
        <TextBlock Text="Hex values, e.g. #4A9EFF. Applied immediately on Save."
                   Foreground="#555577" FontSize="10" FontStyle="Italic" Margin="0,0,0,20"/>

        <Separator Background="#2A2A4E" Margin="0,0,0,16"/>

        <!-- ── VOICE ──────────────────────────────────────── -->
        <TextBlock Text="VOICE" Foreground="#4A9EFF" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock Text="Cartesia voice" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,6"/>
        <ComboBox x:Name="VoiceCombo"
                  Background="#0D0D1E" Foreground="White"
                  BorderBrush="#3A3A5E" Height="30"
                  Margin="0,0,0,4"/>
        <TextBlock Text="Applied immediately on Save."
                   Foreground="#555577" FontSize="10" FontStyle="Italic" Margin="0,0,0,20"/>

        <Separator Background="#2A2A4E" Margin="0,0,0,16"/>

        <!-- ── LOGGING ────────────────────────────────────── -->
        <TextBlock Text="LOGGING" Foreground="#4A9EFF" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Text="Log level" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,6"/>
        <ComboBox x:Name="LogLevelCombo"
                  Background="#0D0D1E" Foreground="White"
                  BorderBrush="#3A3A5E" Height="30"
                  Margin="0,0,0,12"/>

        <TextBlock Text="Log folder" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,6"/>
        <TextBox x:Name="LogFolderBox" Margin="0,0,0,4"/>
        <TextBlock Text="Logging changes take effect after restart."
                   Foreground="#555577" FontSize="10" FontStyle="Italic" Margin="0,0,0,20"/>

        <Separator Background="#2A2A4E" Margin="0,0,0,16"/>

        <!-- ── API KEYS ────────────────────────────────────── -->
        <TextBlock Text="API KEYS" Foreground="#4A9EFF" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock TextWrapping="Wrap" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,10">
            Worker URL, AssemblyAI key, Cartesia key. Changes take effect after restart.
        </TextBlock>
        <Button Content="Open API Configuration →" Style="{StaticResource SecondaryBtn}"
                HorizontalAlignment="Left" Padding="16,8"
                Click="ApiConfig_Click" Margin="0,0,0,20"/>

        <Separator Background="#2A2A4E" Margin="0,0,0,16"/>

        <!-- ── STATUS ─────────────────────────────────────── -->
        <Border x:Name="StatusBorder" Background="#0D1A0D" BorderBrush="#1A3A1A"
                BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock x:Name="StatusText" Foreground="#55CC55" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- ── ACTIONS ────────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource SecondaryBtn}"
                    Width="84" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Save" Style="{StaticResource PrimaryBtn}"
                    Width="84" Click="Save_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
