<Window x:Class="Clicky.Overlay.CursorOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Left="0" Top="0"
        IsHitTestVisible="False">
    <Canvas x:Name="RootCanvas">

        <!-- Cursor glow — hidden mode only: soft colored halo centered on the real cursor during active states -->
        <Ellipse x:Name="CursorGlow" Width="48" Height="48" Opacity="0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#994A9EFF" Offset="0.0"/>
                    <GradientStop Color="#334A9EFF" Offset="0.65"/>
                    <GradientStop Color="#004A9EFF" Offset="1.0"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Triangle — idle state, always follows the real mouse cursor -->
        <Polygon x:Name="Triangle"
                 Points="0,0 -9,21 9,21"
                 Fill="#4A9EFF"
                 Stroke="White"
                 StrokeThickness="1.5">
            <Polygon.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="TriangleScale"/>
                    <RotateTransform x:Name="TriangleRotate"/>
                    <TranslateTransform x:Name="TrianglePos"/>
                </TransformGroup>
            </Polygon.RenderTransform>
        </Polygon>

        <!-- Waveform bars — listening state (5 bars, positioned/sized in code) -->
        <Rectangle x:Name="Bar1" Width="3" Fill="#4A9EFF" RadiusX="1.5" RadiusY="1.5" Opacity="0"/>
        <Rectangle x:Name="Bar2" Width="3" Fill="#4A9EFF" RadiusX="1.5" RadiusY="1.5" Opacity="0"/>
        <Rectangle x:Name="Bar3" Width="3" Fill="#4A9EFF" RadiusX="1.5" RadiusY="1.5" Opacity="0"/>
        <Rectangle x:Name="Bar4" Width="3" Fill="#4A9EFF" RadiusX="1.5" RadiusY="1.5" Opacity="0"/>
        <Rectangle x:Name="Bar5" Width="3" Fill="#4A9EFF" RadiusX="1.5" RadiusY="1.5" Opacity="0"/>

        <!-- Spinner — processing state (partial circle stroke, rotated in code) -->
        <Ellipse x:Name="Spinner"
                 Width="14" Height="14"
                 StrokeThickness="2.5"
                 StrokeDashArray="33 11"
                 Opacity="0">
            <Ellipse.Stroke>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#4A9EFF" Offset="1"/>
                </LinearGradientBrush>
            </Ellipse.Stroke>
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="SpinnerRotate" CenterX="7" CenterY="7"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Speech bubble — appears when triangle lands at a pointed element -->
        <Border x:Name="SpeechBubble" Opacity="0" CornerRadius="6" Padding="8,4"
                Background="#CC1A1A2E">
            <Border.Effect>
                <DropShadowEffect Color="#4A9EFF" BlurRadius="8" Opacity="0.35" ShadowDepth="0"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform x:Name="BubbleScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.RenderTransformOrigin>0,0.5</Border.RenderTransformOrigin>
            <TextBlock x:Name="BubbleText" Foreground="White" FontSize="11" FontWeight="Medium"
                       MaxWidth="200" TextWrapping="Wrap"/>
        </Border>

    </Canvas>
</Window>
